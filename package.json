{
  "name": "sorter",
  "version": "1.2.0",
  "description": "Sorter — Brotherhood generation triage & organizer",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:mac": "electron-vite build && electron-builder --mac",
    "release": "bash scripts/publish.sh",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Brotherhood",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.brotherhood.sorter",
    "productName": "Sorter",
    "publish": {
      "provider": "github",
      "owner": "createdbynoone",
      "repo": "sorter",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "background": "build/background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 216,
          "type": "file"
        },
        {
          "x": 410,
          "y": 216,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "iconSize": 80
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*.png"
        ]
      },
      {
        "from": "build/watermarks",
        "to": "watermarks",
        "filter": [
          "**/*.png"
        ]
      }
    ]
  }
}
